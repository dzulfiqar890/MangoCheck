# MangoCheck — Contoh Environment Variable
# Salin file ini menjadi .env sebelum menjalankan server lokal:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
#
# File .env TIDAK boleh di-commit ke Git (sudah ada di .gitignore).
# File ini hanya berisi contoh nilai — tidak ada data rahasia di sini.

# =============================================================================
# FLASK
# =============================================================================

# Mode debug. Set false untuk production.
FLASK_DEBUG=true

# Host dan port server lokal.
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# =============================================================================
# MODEL
# =============================================================================

# Path absolut atau relatif ke file model TFLite.
# Default: model/mango_classifier.tflite (relatif dari root project).
# MODEL_PATH=model/mango_classifier.tflite

# Dimensi input model. Harus sama dengan ukuran input saat training.
MODEL_INPUT_WIDTH=224
MODEL_INPUT_HEIGHT=224

# Urutan kelas model. HARUS sama persis dengan urutan kelas saat training.
# Jika urutan berbeda, prediksi akan salah meskipun model berjalan normal.
CLASS_LABELS=unripe,ripe,rotten

# Versi model untuk ditampilkan di respons API.
MODEL_VERSION=1.0.0

# Tipe output model:
#   probabilities = output sudah berupa probabilitas (jangan softmax lagi)
#   logits        = output adalah logit mentah (backend akan softmax)
MODEL_OUTPUT_TYPE=probabilities

# Mode normalisasi gambar. Harus sama dengan preprocessing saat training:
#   0_1    = pixel / 255.0               (rentang 0.0 hingga 1.0)
#   neg1_1 = (pixel / 127.5) - 1.0      (rentang -1.0 hingga 1.0, MobileNetV2)
#   none   = tidak ada normalisasi
NORMALIZATION_MODE=0_1

# =============================================================================
# VALIDASI UPLOAD
# =============================================================================

# Batas ukuran file upload dalam MB.
MAX_UPLOAD_SIZE_MB=4

# Batas total piksel gambar (lebar x tinggi). Mencegah decompression bomb.
MAX_IMAGE_PIXELS=50000000

# =============================================================================
# CONFIDENCE
# =============================================================================

# Threshold confidence (0.0 - 1.0). Prediksi di bawah nilai ini akan
# ditandai manual_review_required.
CONFIDENCE_THRESHOLD=0.70

# =============================================================================
# CORS
# =============================================================================

# Daftar origin yang diizinkan mengakses API, dipisahkan koma.
# Untuk development lokal, izinkan localhost.
# JANGAN gunakan * di production.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500
